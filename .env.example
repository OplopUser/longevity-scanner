# Longevity Scanner — environment configuration
# Copy to .env: cp .env.example .env

# ─── Scan Configuration ──────────────────────────────────────
# Minimum Reddit score to include in report (default: 10)
MIN_REDDIT_SCORE=10

# Sources to scan (comma-separated: reddit,arxiv,news)
SCAN_SOURCES=reddit,arxiv

# ─── Report Configuration ────────────────────────────────────
# Days to include in weekly report (default: 7)
REPORT_DAYS=7

# ─── Delivery ────────────────────────────────────────────────
# Telegram chat ID for report delivery (optional)
# TELEGRAM_CHAT_ID=1276278560
